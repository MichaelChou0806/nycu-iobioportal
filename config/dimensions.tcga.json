      "name": "T stage",
      "type": "ordinal",
      "field": "pathologic_T",
      "advancedSide": "advanced",
      "_levelMatch": "用開頭比對：把 pathologic_T 值（如 T2a、T4b）對到 T1/T2/T3/T4。",
      "levels": [
        {
          "id": "T1",
          "label": "T1",
          "prefix": "T1",
          "default": "baseline"
        },
        {
          "id": "T2",
          "label": "T2",
          "prefix": "T2",
          "default": "baseline"
        },
        {
          "id": "T3",
          "label": "T3",
          "prefix": "T3",
          "default": "advanced"
        },
        {
          "id": "T4",
          "label": "T4",
          "prefix": "T4",
          "default": "advanced"
        }
      ]
    },
    {
      "id": "n_stage",
      "name": "N stage",
