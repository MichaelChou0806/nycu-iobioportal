    {
      "id": "stage",
      "name": "Stage",
      "type": "ordinal",
      "field": "pathologic_stage",
      "advancedSide": "advanced",
      "_levelMatch": "pathologic_stage 值如 'Stage IVA'，對到 I/II/III/IV（用羅馬數字比對，注意 IV 要先於 I 比對以免誤判）。",
      "levels": [
        {
          "id": "I",
          "label": "Stage I",
          "roman": "I",
          "default": "baseline"
        },
        {
          "id": "II",
